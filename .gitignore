# Python
__pycache__/
*.pyc
*.pyo

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# Local tooling / agent state (never shipped)
.claude/
.graphify_*
graphify-out/
CLAUDE.md
PLAN_*.md

# Scratch / temp convention — anything starting with underscore at the
# REPO ROOT is a local scratch file (audits, notes, throwaway scripts,
# screenshots). The leading slash pins the pattern to the root so it
# doesn't collide with Python dunder files like pivbo/__init__.py.
/_*

# Internal planning docs — handover notes, roadmaps, parking docs. These
# are developer-only and not useful to end users.
*_handover.md
distribution_handover.md
duel_mode_handover.md
self_duel_mode_handover.md

# Briefcase build logs (regenerated on every build).
logs/

# Local user state (generated at runtime, not shipped)
simulations/
templates/
analyses/
drawings.json
sandbox/

# Briefcase build artifacts (regenerated by `briefcase create/build`)
build/
dist/
.briefcase/
*.dist-info/

# OS
.DS_Store
Thumbs.db
.git_github_backup/
